<header class="header" data-header data-section-id="{{ section.id }}">
  <div class="header__inner">
    <div class="header__left">
      <button class="header__menu-toggle" data-menu-open aria-label="Open menu">
        {%- render 'icon-menu' -%}
      </button>

      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ shop.name | escape }}"
            height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio }}"
            width="{{ section.settings.logo_width }}"
            style="max-width: {{ section.settings.logo_width }}px;"
            loading="eager"
          >
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      <ul class="header__nav-list">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a href="{{ link.url }}" class="header__nav-link"
              {%- if link.current %} aria-current="page"{% endif -%}>
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="header__actions">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="header__action-btn" aria-label="Search">
          {%- render 'icon-search' -%}
        </a>
      {%- endif -%}

      <a href="{{ routes.account_url }}" class="header__action-btn" aria-label="Account">
        {%- render 'icon-account' -%}
      </a>

      <button class="header__action-btn" data-cart-drawer-open aria-label="Cart">
        {%- render 'icon-cart' -%}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        {%- endif -%}
      </button>
    </div>
  </div>
</header>

<!-- Mobile Navigation -->
<nav class="mobile-nav" data-mobile-nav aria-hidden="true" role="navigation" aria-label="Mobile navigation">
  <div class="mobile-nav__header">
    <a href="{{ routes.root_url }}" class="header__logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name | escape }}"
          width="100"
          loading="lazy"
        >
      {%- else -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <button class="mobile-nav__close" data-menu-close aria-label="Close menu">
      {%- render 'icon-close' -%}
    </button>
  </div>

  <ul class="mobile-nav__list">
    {%- for link in section.settings.menu.links -%}
      <li>
        <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
      </li>
    {%- endfor -%}
  </ul>

  <div class="mobile-nav__footer">
    <a href="{{ routes.account_url }}" class="mobile-nav__link">Account</a>
    <a href="{{ routes.search_url }}" class="mobile-nav__link">Search</a>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width",
      "min": 50,
      "max": 250,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky Header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search Icon",
      "default": true
    }
  ]
}
{% endschema %}
