<section class="page-template" data-section-id="{{ section.id }}">
  <div class="container">
    <h1 class="page-template__title">{{ page.title }}</h1>
    <div class="page-template__content">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "class": "main-page-section",
  "settings": []
}
{% endschema %}
