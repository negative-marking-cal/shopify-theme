<section class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="split{% if section.settings.reverse_layout %} split--reverse{% endif %}">
      <div class="split__media img-reveal">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="{{ section.settings.image | image_url: width: 450 }} 450w, {{ section.settings.image | image_url: width: 700 }} 700w, {{ section.settings.image | image_url: width: 900 }} 900w"
            sizes="(min-width: 750px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | escape | default: section.settings.title }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
      <div class="split__content reveal">
        {%- if section.settings.subtitle != blank -%}
          <p class="split__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="split__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="split__text">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "class": "brand-story-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Our Craft" },
    { "type": "text", "id": "title", "label": "Title", "default": "Precision in Every Thread" },
    { "type": "richtext", "id": "text", "label": "Content", "default": "<p>We combine cutting-edge computerized embroidery technology with artisan design sensibility. Each piece undergoes meticulous quality checks.</p>" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Learn More" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "checkbox", "id": "reverse_layout", "label": "Image on Right", "default": false }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
