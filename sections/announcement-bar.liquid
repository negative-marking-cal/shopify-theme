{%- if section.blocks.size > 0 -%}
<div class="announcement-bar" data-section-id="{{ section.id }}">
  <div class="announcement-bar__slider">
    {%- for block in section.blocks -%}
      <div class="announcement-bar__message" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
        {%- else -%}
          <span>{{ block.settings.text }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "class": "announcement-bar-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over ₹999"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "Free shipping on orders over ₹999"
          }
        }
      ]
    }
  ]
}
{% endschema %}
