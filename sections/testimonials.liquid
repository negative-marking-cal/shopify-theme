<section class="section section--alt" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="testimonials__header reveal">
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div class="testimonials__grid stagger-children">
      {%- for block in section.blocks -%}
        <div class="testimonial-card reveal" {{ block.shopify_attributes }}>
          <span class="testimonial-card__quote">"</span>
          <div class="testimonial-card__stars">
            {%- for i in (1..block.settings.rating) -%}&#9733;{%- endfor -%}
          </div>
          {%- if block.settings.text != blank -%}
            <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
          {%- endif -%}
          {%- if block.settings.author != blank -%}
            <p class="testimonial-card__author">{{ block.settings.author }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "class": "testimonials-section",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Reviews" },
    { "type": "text", "id": "title", "label": "Title", "default": "What Our Customers Say" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review Text", "default": "The quality is incredible." },
        { "type": "text", "id": "author", "label": "Author", "default": "Happy Customer" }
      ]
    }
  ],
  "presets": [{
    "name": "Testimonials",
    "blocks": [
      { "type": "testimonial", "settings": { "rating": 5, "text": "The embroidery quality is insane. You can feel the craftsmanship.", "author": "Rahul S." } },
      { "type": "testimonial", "settings": { "rating": 5, "text": "Ordered two oversized tees. Stitching is next level. Worth every rupee.", "author": "Priya M." } },
      { "type": "testimonial", "settings": { "rating": 5, "text": "Finally a brand that does embroidery right. Clean, great fit, fast delivery.", "author": "Arjun K." } }
    ]
  }]
}
{% endschema %}
