<section class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="testimonials__header animate-in">
      {%- if section.settings.subtitle != blank -%}
        <p class="featured-collection__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2>{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card animate-in" style="transition-delay: {{ forloop.index | times: 0.1 }}s;" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {%- for i in (1..block.settings.rating) -%}&#9733;{%- endfor -%}
          </div>
          {%- if block.settings.text != blank -%}
            <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
          {%- endif -%}
          {%- if block.settings.author != blank -%}
            <p class="testimonial-card__author">— {{ block.settings.author }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "class": "testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Our Customers Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "The embroidery quality is insane. You can feel the craftsmanship the moment you hold the tee. Definitely ordering more."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Rahul S."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The embroidery quality is insane. You can feel the craftsmanship the moment you hold the tee.",
            "author": "Rahul S."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Ordered two oversized tees. The stitching detail is next level and the fabric feels premium. Worth every rupee.",
            "author": "Priya M."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Finally a brand that does embroidery right. Clean designs, great fit, and fast delivery. My new go-to.",
            "author": "Arjun K."
          }
        }
      ]
    }
  ]
}
{% endschema %}
