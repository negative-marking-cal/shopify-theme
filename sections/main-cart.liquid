<section class="cart-page" data-section-id="{{ section.id }}">
  <div class="container">
    <h1 class="cart-page__title">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="cart-table">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <div class="cart-item__image">
                {%- if item.image -%}
                  <a href="{{ item.url }}">
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.title | escape }}"
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </a>
                {%- endif -%}
              </div>

              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}

                <div class="cart-item__bottom">
                  <div class="quantity-selector" data-quantity-selector>
                    <button type="button" class="quantity-selector__btn" data-qty-decrease aria-label="Decrease quantity">-</button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      class="quantity-selector__value"
                      data-qty-input
                      aria-label="Quantity for {{ item.title }}"
                    >
                    <button type="button" class="quantity-selector__btn" data-qty-increase aria-label="Increase quantity">+</button>
                  </div>
                  <p class="cart-item__price">{{ item.final_line_price | money }}</p>
                </div>

                <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0" class="cart-item__remove">Remove</a>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-footer">
          <div class="cart-footer__subtotal">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p class="cart-footer__note">Shipping & taxes calculated at checkout</p>

          <div class="cart-footer__actions">
            <button type="submit" name="update" class="btn btn--secondary btn--wide">Update Cart</button>
            <button type="submit" name="checkout" class="btn btn--primary btn--wide">Checkout</button>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="cart-page__empty">
        <p style="margin-bottom:1.5rem;opacity:0.7;">Your cart is currently empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Continue Shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "class": "main-cart-section",
  "settings": []
}
{% endschema %}
