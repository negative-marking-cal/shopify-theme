{%- style -%}
  .hero-slider {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
  }
  .hero-slider__track {
    display: flex;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-slider__slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }
  .hero-slider__media {
    position: absolute;
    inset: 0;
  }
  .hero-slider__media img,
  .hero-slider__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
  }
  .hero-slider__content {
    position: relative;
    z-index: 3;
    padding: var(--space-3xl) var(--page-gutter);
    max-width: 600px;
    color: #fff;
  }
  .hero-slider__title {
    font-size: var(--text-2xl);
    font-weight: 300;
    color: #fff;
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }
  .hero-slider__description {
    font-size: var(--text-sm);
    opacity: 0.8;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    max-width: 400px;
  }
  .hero-slider__nav {
    position: absolute;
    bottom: var(--space-xl);
    right: var(--page-gutter);
    z-index: 4;
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .hero-slider__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }
  .hero-slider__dot.is-active {
    background: #fff;
    width: 24px;
    border-radius: 4px;
  }
  .hero-slider__counter {
    position: absolute;
    bottom: var(--space-xl);
    left: var(--page-gutter);
    z-index: 4;
    color: rgba(255,255,255,0.6);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
  }
  @media (min-width: 750px) {
    .hero-slider__content {
      padding: var(--space-4xl) calc(var(--page-gutter) * 2);
      max-width: 700px;
    }
    .hero-slider__title { font-size: var(--text-3xl); }
  }
  @media (max-width: 749px) {
    .hero-slider { height: 90vh; height: 90svh; }
    .hero-slider__content { padding: var(--space-2xl) var(--page-gutter); }
    .hero-slider__title { font-size: clamp(1.8rem, 6vw, 2.5rem); }
  }
{%- endstyle -%}

<section class="hero-slider" data-section-id="{{ section.id }}" data-hero-slider>
  <div class="hero-slider__track" data-slider-track>
    {%- for block in section.blocks -%}
      <div class="hero-slider__slide" {{ block.shopify_attributes }}>
        <div class="hero-slider__media">
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
          {%- elsif block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1920 }}"
              srcset="{{ block.settings.image | image_url: width: 750 }} 750w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1920 }} 1920w"
              sizes="100vw"
              alt="{{ block.settings.image.alt | escape | default: block.settings.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              {% if forloop.first %}fetchpriority="high"{% endif %}
            >
          {%- else -%}
            {%- render 'placeholder-hero', index: forloop.index -%}
          {%- endif -%}
        </div>
        <div class="hero-slider__overlay"></div>
        <div class="hero-slider__content">
          {%- if block.settings.title != blank -%}
            <h2 class="hero-slider__title">{{ block.settings.title }}</h2>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="hero-slider__description">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="btn btn--white">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="hero-slider__counter" data-slider-counter>
      <span data-slider-current>01</span> / <span>{{ section.blocks.size | prepend: '0' | slice: -2, 2 }}</span>
    </div>
    <div class="hero-slider__nav" data-slider-nav>
      {%- for block in section.blocks -%}
        <button class="hero-slider__dot{% if forloop.first %} is-active{% endif %}" data-slider-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Slider",
  "class": "hero-slider-section",
  "max_blocks": 5,
  "settings": [
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay (seconds)", "min": 3, "max": 10, "step": 1, "unit": "s", "default": 5 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "video", "id": "video", "label": "Video (optional)" },
        { "type": "textarea", "id": "title", "label": "Title", "default": "Where Art Meets Thread" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Premium computerized embroidery on handpicked fabrics." },
        { "type": "text", "id": "button_label", "label": "Button", "default": "Shop Now" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Hero Slider",
    "blocks": [
      { "type": "slide", "settings": { "title": "Where Art Meets Thread", "description": "Premium computerized embroidery on handpicked fabrics. Each piece is a wearable work of art.", "button_label": "Shop Collection" } },
      { "type": "slide", "settings": { "title": "1,000 Stitches Per Minute", "description": "Computerized precision meets artisan design.", "button_label": "Explore" } },
      { "type": "slide", "settings": { "title": "The Art Collection", "description": "Hand-drawn designs transformed into thread. Limited edition.", "button_label": "Shop Limited" } }
    ]
  }]
}
{% endschema %}
