{%- style -%}
  #section-{{ section.id }} .hero__overlay {
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<section id="section-{{ section.id }}" class="hero hero--{{ section.settings.text_color_scheme }}" data-section-id="{{ section.id }}">
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.image | image_url: width: 750 }} 750w,
          {{ section.settings.image | image_url: width: 1100 }} 1100w,
          {{ section.settings.image | image_url: width: 1500 }} 1500w,
          {{ section.settings.image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape | default: section.settings.title }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
    {%- endif -%}
  </div>

  <div class="hero__overlay"></div>

  <div class="hero__content animate-in">
    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="hero__title">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="hero__description">{{ section.settings.description }}</p>
    {%- endif -%}

    <div class="hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="btn btn--secondary" style="border-color:currentColor;">
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "class": "hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background Video (optional)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Crafted With Precision"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Where Art Meets Thread"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium computerized embroidery on handpicked fabrics. Each piece is a wearable work of art."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Second Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second Button Link"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "select",
      "id": "text_color_scheme",
      "label": "Text Color",
      "options": [
        { "value": "light", "label": "White Text" },
        { "value": "dark", "label": "Dark Text" }
      ],
      "default": "light"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
