<section class="section" data-section-id="{{ section.id }}">
  <div class="container" style="text-align:center;padding:5rem 1.25rem;">
    <h1 style="margin-bottom:1rem;">Page Not Found</h1>
    <p style="margin-bottom:2rem;opacity:0.7;">Sorry, the page you're looking for doesn't exist or has been moved.</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary">Back to Home</a>
  </div>
</section>

{% schema %}
{
  "name": "404 Page",
  "class": "main-404-section",
  "settings": []
}
{% endschema %}
