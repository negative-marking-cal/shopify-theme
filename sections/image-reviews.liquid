{%- style -%}
  .image-reviews { padding: var(--space-3xl) 0; overflow: hidden; }
  .image-reviews__header { text-align: center; margin-bottom: var(--space-2xl); }
  .image-reviews__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }
  .image-review {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    cursor: pointer;
  }
  .image-review img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .image-review:hover img { transform: scale(1.05); }
  .image-review__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: var(--space-lg);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .image-review:hover .image-review__overlay { opacity: 1; }
  .image-review__info { color: #fff; }
  .image-review__stars { font-size: 0.75rem; color: var(--color-accent-light); margin-bottom: 0.3rem; }
  .image-review__text { font-size: var(--text-xs); line-height: 1.5; opacity: 0.9; margin-bottom: 0.3rem; }
  .image-review__author { font-size: 0.7rem; opacity: 0.7; }
  @media (min-width: 750px) {
    .image-reviews__grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 749px) {
    .image-review__overlay { opacity: 1; background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 40%); }
  }
{%- endstyle -%}

<section class="image-reviews" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="image-reviews__header reveal">
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
  </div>
  <div class="container--wide" style="max-width:1440px;margin:0 auto;padding:0 var(--page-gutter);">
    <div class="image-reviews__grid stagger-children">
      {%- for block in section.blocks -%}
        <div class="image-review reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.author }}" loading="lazy">
          {%- else -%}
            {%- render 'placeholder-product', index: forloop.index -%}
          {%- endif -%}
          <div class="image-review__overlay">
            <div class="image-review__info">
              <div class="image-review__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              {%- if block.settings.text != blank -%}
                <p class="image-review__text">"{{ block.settings.text | truncate: 80 }}"</p>
              {%- endif -%}
              <p class="image-review__author">— {{ block.settings.author }}</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image Reviews",
  "class": "image-reviews-section",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "#StitchAndCo" },
    { "type": "text", "id": "title", "label": "Title", "default": "Worn by You" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Image Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Customer Photo" },
        { "type": "text", "id": "text", "label": "Short Review", "default": "Absolutely love the quality!" },
        { "type": "text", "id": "author", "label": "Author", "default": "@customer" }
      ]
    }
  ],
  "presets": [{
    "name": "Image Reviews",
    "blocks": [
      { "type": "review", "settings": { "text": "Obsessed with the detail!", "author": "@rahul.style" } },
      { "type": "review", "settings": { "text": "Best tee I own, period.", "author": "@priya.fits" } },
      { "type": "review", "settings": { "text": "Embroidery on another level", "author": "@arjun.k" } },
      { "type": "review", "settings": { "text": "Compliments every time I wear it", "author": "@sneha.m" } }
    ]
  }]
}
{% endschema %}
