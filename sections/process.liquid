<section class="section process" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="process__header reveal">
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="section-description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="process__grid stagger-children">
      {%- for block in section.blocks -%}
        <div class="process__step reveal" {{ block.shopify_attributes }}>
          <div class="process__step-number"></div>
          <div class="process__step-icon">
            {%- case block.settings.icon -%}
              {%- when 'design' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
              {%- when 'stitch' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              {%- when 'quality' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {%- when 'ship' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endcase -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="process__step-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="process__step-text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Process Steps",
  "class": "process-section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "From Concept to Creation"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every piece goes through a meticulous 4-step process to ensure perfection."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "design", "label": "Design" },
            { "value": "stitch", "label": "Stitch/Craft" },
            { "value": "quality", "label": "Quality Check" },
            { "value": "ship", "label": "Shipping" },
            { "value": "star", "label": "Star" }
          ],
          "default": "design"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Design"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Each embroidery pattern is designed by our in-house artists with precision and attention to detail."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "design",
            "title": "Design",
            "text": "Original artwork created by our in-house design team, digitized for embroidery perfection."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "stitch",
            "title": "Embroider",
            "text": "1,000+ stitches per minute with computerized precision. Every thread placed intentionally."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "quality",
            "title": "Quality Check",
            "text": "Each piece inspected for stitch density, color accuracy, and fabric integrity before packing."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "ship",
            "title": "Deliver",
            "text": "Carefully packed and shipped to your doorstep. Unwrap your wearable art."
          }
        }
      ]
    }
  ]
}
{% endschema %}
