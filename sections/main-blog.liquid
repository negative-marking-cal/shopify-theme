<section class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <h1 class="collection-header__title" style="text-align:center;margin-bottom:2.5rem;">{{ blog.title }}</h1>

    {%- paginate blog.articles by section.settings.posts_per_page -%}
      <div class="grid grid--3">
        {%- for article in blog.articles -%}
          <article class="blog-card animate-in" style="transition-delay: {{ forloop.index | times: 0.1 }}s;">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="blog-card__media" style="display:block;aspect-ratio:16/10;overflow:hidden;margin-bottom:1rem;">
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.image.alt | escape | default: article.title }}"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                  loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;"
                >
              </a>
            {%- endif -%}
            <p class="text-small text-uppercase text-accent" style="margin-bottom:0.4rem;">
              {{ article.published_at | date: '%B %d, %Y' }}
            </p>
            <h3 style="margin-bottom:0.5rem;">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h3>
            <p class="text-small" style="opacity:0.7;">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination__item">&larr;</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
            {%- else -%}
              <span class="pagination__item{% if part.title == paginate.current_page %} is-active{% endif %}">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination__item">&rarr;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog Posts",
  "class": "main-blog-section",
  "settings": [
    {
      "type": "range",
      "id": "posts_per_page",
      "label": "Posts Per Page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    }
  ]
}
{% endschema %}
