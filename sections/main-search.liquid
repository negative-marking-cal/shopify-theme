<section class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h1>Search</h1>
    </div>

    <div style="max-width:600px;margin:0 auto 3rem;">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <div style="display:flex;gap:0.5rem;">
          <input
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="Search products..."
            class="newsletter__input"
            style="flex:1;"
            aria-label="Search"
          >
          <button type="submit" class="btn btn--primary">Search</button>
        </div>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="text-center text-small" style="margin-bottom:2rem;opacity:0.6;">
          {{ search.results_count }} results for "{{ search.terms }}"
        </p>
        <div class="collection-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'product-card', product: item, show_vendor: false -%}
            {%- else -%}
              <div class="product-card">
                <div class="product-card__info">
                  <h3 class="product-card__title"><a href="{{ item.url }}">{{ item.title }}</a></h3>
                  <p class="text-small" style="opacity:0.7;">{{ item.content | strip_html | truncate: 100 }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div style="text-align:center;padding:3rem 0;">
          <p style="margin-bottom:1.5rem;opacity:0.7;">No results found for "{{ search.terms }}"</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Browse All Products</a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search Results",
  "class": "main-search-section",
  "settings": []
}
{% endschema %}
