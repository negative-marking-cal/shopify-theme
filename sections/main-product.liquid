<section class="product-page" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="product-page__grid">
      <!-- Gallery -->
      <div class="product-gallery">
        <div class="product-gallery__main" data-gallery-main>
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 900 }}"
              srcset="
                {{ product.featured_image | image_url: width: 500 }} 500w,
                {{ product.featured_image | image_url: width: 700 }} 700w,
                {{ product.featured_image | image_url: width: 900 }} 900w
              "
              sizes="(min-width: 750px) 50vw, 100vw"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              loading="eager"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images -%}
              <button
                class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                data-gallery-thumb="{{ image | image_url: width: 900 }}"
                data-srcset="{{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 900 }} 900w"
                aria-label="View image {{ forloop.index }}"
              >
                <img src="{{ image | image_url: width: 100 }}" alt="{{ image.alt | escape }}" width="80" height="80" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Product Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__price">
          <span data-product-price>{{ product.selected_or_first_available_variant.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-info__price-compare" data-product-compare-price>{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>


        {%- form 'product', product, data-product-form: '' -%}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="variant-picker" data-option-group>
                <label class="variant-picker__label">
                  {{ option.name }}
                  <span class="variant-picker__selected" data-option-selected>{{ option.selected_value }}</span>
                </label>
                <div class="variant-picker__options">
                  {%- for value in option.values -%}
                    <button type="button"
                      class="variant-picker__option{% if option.selected_value == value %} is-active{% endif %}"
                      data-variant-option="{{ value }}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-selected-variant>

          <div class="quantity-selector" data-quantity-selector>
            <button type="button" class="quantity-selector__btn" data-qty-decrease aria-label="Decrease">−</button>
            <input type="number" name="quantity" value="1" min="1" class="quantity-selector__value" data-qty-input aria-label="Quantity">
            <button type="button" class="quantity-selector__btn" data-qty-increase aria-label="Increase">+</button>
          </div>

          <button type="submit" class="btn btn--primary btn--wide btn--large" data-add-to-cart
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            <span data-btn-text>
              {%- if product.selected_or_first_available_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
            </span>
          </button>
        {%- endform -%}


        <!-- Product Tabs -->
        <div class="product-tabs">
          <div class="product-tabs__nav">
            <button class="product-tabs__tab is-active" data-tab-trigger="description">Description</button>
            {%- if section.settings.size_guide != blank -%}
              <button class="product-tabs__tab" data-tab-trigger="sizing">Size Guide</button>
            {%- endif -%}
            <button class="product-tabs__tab" data-tab-trigger="care">Care Instructions</button>
            <button class="product-tabs__tab" data-tab-trigger="shipping">Shipping</button>
          </div>

          <div class="product-tabs__panel is-active" data-tab-panel="description">
            {{ product.description }}
          </div>

          {%- if section.settings.size_guide != blank -%}
            <div class="product-tabs__panel" data-tab-panel="sizing">
              {{ section.settings.size_guide }}
            </div>
          {%- endif -%}

          <div class="product-tabs__panel" data-tab-panel="care">
            {{ section.settings.care_instructions | default: '<p>Machine wash cold with like colors. Tumble dry low. Do not iron over embroidery. Do not bleach.</p>' }}
          </div>

          <div class="product-tabs__panel" data-tab-panel="shipping">
            {{ section.settings.shipping_info | default: '<p>Free shipping on orders over ₹999. Standard delivery in 5-7 business days. Express delivery available.</p>' }}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Variants JSON -->
  <script type="application/json" data-product-variants>{{ product.variants | json }}</script>

  <!-- Mobile Sticky ATC -->
  <div class="product-sticky-atc" data-sticky-atc>
    <div class="product-sticky-atc__inner">
      <div class="product-sticky-atc__info">
        <p class="product-sticky-atc__title">{{ product.title }}</p>
        <p class="product-sticky-atc__price">{{ product.selected_or_first_available_variant.price | money }}</p>
      </div>
      <button class="btn btn--primary btn--small" onclick="document.querySelector('[data-add-to-cart]').click();">
        Add to Cart
      </button>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Product Page",
  "class": "main-product-section",
  "settings": [
    {
      "type": "richtext",
      "id": "size_guide",
      "label": "Size Guide Content"
    },
    {
      "type": "richtext",
      "id": "care_instructions",
      "label": "Care Instructions",
      "default": "<p>Machine wash cold with like colors. Tumble dry low. Do not iron over embroidery. Do not bleach.</p>"
    },
    {
      "type": "richtext",
      "id": "shipping_info",
      "label": "Shipping Information",
      "default": "<p>Free shipping on orders over ₹999. Standard delivery in 5-7 business days. Express delivery available.</p>"
    }
  ]
}
{% endschema %}
