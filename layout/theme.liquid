<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ settings.text_direction | default: 'ltr' }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta name="theme-color" content="{{ settings.color_accent }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{- page_title -}}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- render 'meta-tags' -%}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

  {%- unless settings.font_heading.system? and settings.font_body.system? -%}
    <link rel="preload" as="font" href="{{ settings.font_heading | font_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ settings.font_body | font_url }}" type="font/woff2" crossorigin>
  {%- endunless -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --color-bg: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-accent: {{ settings.color_accent }};
      --color-accent-light: {{ settings.color_accent_light }};
      --color-border: {{ settings.color_border }};
      --color-btn-bg: {{ settings.color_button_bg }};
      --color-btn-text: {{ settings.color_button_text }};
      --color-btn-secondary-bg: {{ settings.color_button_secondary_bg }};
      --color-btn-secondary-text: {{ settings.color_button_secondary_text }};

      --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
      --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
      --font-size-base: {{ settings.font_size_base }}px;

      --page-width: {{ settings.page_width }}px;
      --section-spacing: {{ settings.section_spacing }}px;

      --header-height: 70px;
      --announcement-height: 40px;
    }

    {{ settings.font_heading | font_face: font_display: 'swap' }}
    {{ settings.font_body | font_face: font_display: 'swap' }}
  </style>

  {{ content_for_header }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.theme = {
      moneyFormat: {{ shop.money_format | json }},
      cartUrl: '{{ routes.cart_url }}',
      rootUrl: '{{ routes.root_url }}'
    };
  </script>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content" href="#main-content">{{ 'accessibility.skip_to_content' | t }}</a>

  {%- sections 'header-group' -%}

  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  {%- if settings.cart_type == 'drawer' -%}
    {%- render 'cart-drawer' -%}
  {%- endif -%}

  <div class="overlay" data-overlay></div>
</body>
</html>
